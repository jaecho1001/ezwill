DATABASE_URL=postgresql://user:password@localhost:5432/caselawvision
DEFAULT_SCHEMA=firm_demo
EZWILL_PORT=8003

# OpenAI — used by quick_draft agent capability
OPENAI_API_KEY=

# Anthropic — used by conversational intake chat (/api/ai/intake/chat).
# Without this key the route falls back to a regex extractor so dev still
# works offline. In prod, leaving it blank means users always see the
# pattern-matcher fallback.
ANTHROPIC_API_KEY=
# Model override. Default: claude-sonnet-4-5 (best quality).
# Switch to claude-haiku-4-5-20251001 for ~5–10x cost reduction if quality is acceptable.
ANTHROPIC_INTAKE_MODEL=claude-sonnet-4-5

# Per-draft sliding-window rate limit on the intake chat route. Defaults
# below allow 20 requests per 60s per draft_id. Raise the window or drop
# the max to tighten. In-process only — use Redis for multi-worker prod.
AI_INTAKE_RATE_WINDOW_SECS=60
AI_INTAKE_RATE_MAX_REQS=20

# Firm identity (used in notifications)
FIRM_EMAIL=lawyers@vaturicho.com
FIRM_NAME=Vaturi & Cho LLP
FIRM_PHONE=+14166614529
FROM_EMAIL=noreply@ezwill.app
BASE_URL=http://localhost:3000

# GoHighLevel (GHL) — unified email + SMS delivery
# Sign up: https://app.gohighlevel.com
# API docs: https://highlevel.stoplight.io/docs/integrations
GHL_API_KEY=
GHL_LOCATION_ID=

# Notification mode: 'ghl' (production), 'stdout' (dev — logs to console), 'disabled'
NOTIFICATION_MODE=stdout

# Dashboard auth
DASHBOARD_PASSWORD=vaturi2026
SECRET_KEY=change-this-in-production
